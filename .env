# Observium DB connection (read-only access is sufficient)
OBSERVIUM_DB_HOST=127.0.0.1
OBSERVIUM_DB_PORT=3306
OBSERVIUM_DB_NAME=observium
OBSERVIUM_DB_USER=observium
OBSERVIUM_DB_PASS=VwT2m1QMIeF20jp4723i4nJzo8kR51Yj

# Snapshot output directory (must be writable by the exporter, readable by the backend)
NETVIZ_SNAPSHOT_DIR=/home/lasco/workspace/netviz/snapshot

# Backend
NETVIZ_HOST=0.0.0.0
NETVIZ_PORT=8080
NETVIZ_SESSION_SECRET=change-me-to-a-long-random-string
NETVIZ_SESSION_HOURS=8

# Optional: minimum Observium user level required to log in (0-10, 10=admin)
NETVIZ_MIN_USER_LEVEL=1
